{
  "name": "digitalcv",
  "version": "1.0.0",
  "description": "DigitalCV: CV interactivo y dinámico desarrollado con Node.js, Express y React.",
  "main": "server/index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node server/index.js",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cross-env NODE_ENV=development nodemon --exitcrash server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "npm run client:build",
    "client:build": "cd client && npm run build",
    "test": "node --check server/index.js && node --check server/routes/publicRoutes.js && node --check server/routes/adminRoutes.js && node --check server/routes/analyticsRoutes.js && node --check server/middleware/authMiddleware.js && node --check server/utils/jsonStorage.js"
  },
  "keywords": [
    "cv",
    "portfolio",
    "express",
    "react"
  ],
  "author": "Martín Guillén",
  "license": "ISC",
  "dependencies": {
    "bootstrap": "^5.3.8",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.4.2",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14",
    "vite": "^8.0.16"
  }
}
